# Enforce LF line endings for files that run inside Linux containers
*.sh        text eol=lf
*.hcl       text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.env       text eol=lf
*.conf      text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf

# Windows-only files keep CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files — no line ending conversion
*.joblib    binary
*.png       binary
*.jpg       binary
*.ico       binary
